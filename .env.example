# ================================
# API系统环境变量配置文件
# ================================
# 
# 使用说明：
# 1. 将此文件重命名为 .env
# 2. 根据您的实际环境修改相应配置
# 3. 生产环境中确保 .env 文件不被公开访问
#

# ================================
# 应用基础配置
# ================================
APP_NAME=API系统
APP_VERSION=1.0.0
APP_DEBUG=false
APP_TIMEZONE=Asia/Shanghai
APP_LANG=zh-cn
ADMIN_PATH=admin

# ================================
# 数据库配置
# ================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_username
DB_PASS=your_password
DB_PREFIX=think_

# ================================
# 支付宝配置
# ================================
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_RETURN_URL=
ALIPAY_NOTIFY_URL=

# ================================
# 微信支付配置
# ================================
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_KEY=
WECHAT_CERT_PATH=
WECHAT_KEY_PATH=
WECHAT_NOTIFY_URL=

# ================================
# API系统配置
# ================================
API_HOURLY_LIMIT=1000
API_MINUTE_LIMIT=100
API_DAILY_LIMIT=10000
API_CACHE_APIKEY_TTL=300
API_CACHE_GOODS_TTL=600
API_CACHE_DETAIL_TTL=1800
API_ORDER_EXPIRE=900
API_ORDER_LOCK_TIMEOUT=10

# ================================
# 二维码服务配置
# ================================
QR_CODE_SERVICE=https://api.qrserver.com/v1/create-qr-code/
QR_CODE_SIZE=200x200
QR_CODE_FORMAT=png
QR_CODE_PATH=uploads/qrcode/

# ================================
# 缓存配置
# ================================
CACHE_TYPE=file
CACHE_PREFIX=api_
CACHE_EXPIRE=0

# ================================
# 日志配置
# ================================
LOG_TYPE=file
LOG_LEVEL=error
LOG_FILE_SIZE=2097152
LOG_TIME_FORMAT=c
LOG_MAX_FILES=0

# ================================
# 上传配置
# ================================
UPLOAD_PATH=uploads/
UPLOAD_MAX_SIZE=2097152
UPLOAD_ALLOWED_EXT=jpg,jpeg,png,gif

# ================================
# 安全配置
# ================================
ENCRYPTION_KEY=
TOKEN_EXPIRE=7200
MAX_LOGIN_ATTEMPTS=5
LOGIN_BAN_TIME=300
ALLOWED_IPS=

# ================================
# 邮件配置
# ================================
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=
MAIL_SMTP_PASS=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=API系统

# ================================
# 监控配置
# ================================
MONITOR_ENABLED=true
MONITOR_SLOW_QUERY=1.0
MONITOR_MEMORY_LIMIT=128
MONITOR_ALERT_EMAIL=
MONITOR_ALERT_WEBHOOK=

# ================================
# 第三方服务配置
# ================================
IP_LOCATION_PROVIDER=taobao
IP_LOCATION_API_KEY=
IP_LOCATION_CACHE_TTL=3600

SMS_PROVIDER=
SMS_API_KEY=
SMS_API_SECRET=

# ================================
# SSL配置
# ================================
SSL_ENABLED=false
SSL_CERT_PATH=
SSL_KEY_PATH=
SSL_AUTO_RENEW=false
SSL_EMAIL=
